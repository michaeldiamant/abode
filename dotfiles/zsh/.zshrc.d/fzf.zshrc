zvm_after_init_commands+=('[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh')

# Gruvbox Material Light Soft
export FZF_DEFAULT_OPTS="$FZF_DEFAULT_OPTS \
  --color=fg:#654735,fg+:#4f3829,bg:#f2e5bc,bg+:#eddeb5 \
  --color=hl:#b47109,hl+:#c35e0a \
  --color=border:#d5c4a1,header:#45707a,info:#d5c4a1,spinner:#b47109 \
  --color=pointer:#c14a4a,marker:#6c782e,prompt:#45707a"
